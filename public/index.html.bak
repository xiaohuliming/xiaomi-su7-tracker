        </div>
    </div>

    <div class="card animate-fade-in">
        <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1.5rem;">
            <h2 style="margin: 0;">交付数据-近100条</h2>
            <div style="display: flex; gap: 1rem;">
                <select id="provinceFilter">
                    <option value="">所有省份</option>
                </select>
                <select id="modelFilter">
                    <option value="">所有型号</option>
                    <option value="标准">标准</option>
                    <option value="PRO">PRO</option>
                    <option value="MAX">MAX</option>
                </select>
                <button onclick="refreshData()" style="white-space: nowrap;">刷新数据</button>
            </div>
        </div>
        
        <div class="table-container">
            <table>
                <thead>
                    <tr>
                        <th>订单日期</th>
                        <th>实际交付日期</th>
                        <th>省份</th>
                        <th>车型</th>
                        <th>外观颜色</th>
                        <th>内饰颜色</th>
                        <th>等待天数</th>
                    </tr>
                </thead>
                <tbody id="dataTableBody"></tbody>
            </table>
        </div>
    </div>

    <div class="card animate-fade-in">
        <h2>留言板</h2>
        <div class="input-group">
            <div class="input-field">
                <label>昵称</label>
                <input type="text" id="nickname" placeholder="请输入您的昵称" 
                       style="width: 100%; padding: 0.8rem 1rem; border: 2px solid #eee; border-radius: var(--border-radius-sm);">
            </div>
            <div class="input-field" style="grid-column: 1 / -1;">
                <label>留言内容</label>
                <textarea id="commentContent" 
                          placeholder="说点什么吧..."
                          style="width: 100%; height: 100px; padding: 0.8rem 1rem; border: 2px solid #eee; border-radius: var(--border-radius-sm); resize: vertical;"></textarea>
            </div>
            <div class="input-field">
                <button onclick="submitComment()">发表留言</button>
            </div>
        </div>
        <div id="commentsList" style="margin-top: 2rem;"></div>
    </div>

    <script>
        // 保持原有的JavaScript代码不变，因为这些是功能性代码
        // 仅添加图表样式相关的配置

        Chart.defaults.color = '#666';
        Chart.defaults.font.family = "'SF Pro Text', 'PingFang SC', 'Microsoft YaHei', sans-serif";
        
        const chartConfig = {
            responsive: true,
            maintainAspectRatio: false,
            plugins: {
                legend: {
                    position: 'top',
                    labels: {
                        padding: 20,
                        font: { size: 13 }
                    }
                },
                tooltip: {
                    backgroundColor: 'rgba(0,0,0,0.8)',
                    padding: 12,
                    titleFont: { size: 14 },
                    bodyFont: { size: 13 }
                }
            },
            scales: {
                y: {
                    beginAtZero: true,
                    grid: {
                        color: 'rgba(0,0,0,0.05)'
                    }
                },
                x: {
                    grid: { display: false },
                    ticks: {
                        maxRotation: 45,
                        minRotation: 45
                    }
                }
            }
        };

        // 将原有的JavaScript代码放在这里
        // ...（保持原有的功能性JavaScript代码不变）
        // 声明图表变量
let deliveryTrendChart = null;
let provinceStatsChart = null;

// 绘制交付时间趋势图
function updateDeliveryTrendChart(data) {
    const ctx = document.getElementById('deliveryTrendChart');
    
    if (deliveryTrendChart) {
        deliveryTrendChart.destroy();
    }
    
    const dates = data.records.map(r => r.order_date.split('T')[0]).reverse();
    const waitingDays = data.records.map(r => r.waiting_days).reverse();
    
    deliveryTrendChart = new Chart(ctx, {
        type: 'line',
        data: {
            labels: dates,
            datasets: [{
                label: '等待天数',
                data: waitingDays,
                borderColor: '#ff6700',
                backgroundColor: 'rgba(255, 103, 0, 0.1)',
                borderWidth: 2,
                tension: 0.4,
                fill: true,
                pointBackgroundColor: '#fff',
                pointBorderColor: '#ff6700',
                pointBorderWidth: 2,
                pointRadius: 4,
                pointHoverRadius: 6
            }]
        },
        options: {
            ...chartConfig,
            plugins: {
                ...chartConfig.plugins,
                title: {
                    display: true,
                    text: '交付等待时间变化趋势',
                    padding: 20,
                    font: {
                        size: 16,
                        weight: 600
                    }
                }
            }
        }
    });
}

// 绘制省份统计图
function updateProvinceStatsChart(data) {
    const ctx = document.getElementById('provinceStatsChart');
    
    if (provinceStatsChart) {
        provinceStatsChart.destroy();
    }
    
    const provinceStats = {};
    data.records.forEach(record => {
        if (!provinceStats[record.province]) {
            provinceStats[record.province] = {
                sum: 0,
                count: 0
            };
        }
        provinceStats[record.province].sum += record.waiting_days;
        provinceStats[record.province].count++;
    });
    
    const provinces = Object.keys(provinceStats);
    const avgWaitingDays = provinces.map(p => 
        (provinceStats[p].sum / provinceStats[p].count).toFixed(1)
    );
    
    provinceStatsChart = new Chart(ctx, {
        type: 'bar',
        data: {
            labels: provinces,
            datasets: [{
                label: '平均等待天数',
                data: avgWaitingDays,
                backgroundColor: '#ff6700'
            }]
        },
        options: {
            maintainAspectRatio: false,
            responsive: true,
            plugins: {
                title: {
                    display: true,
                    text: '各省份平均等待时间'
                }
            },
            scales: {
                x: {
                    grid: {
                        display: false
                    },
                    ticks: {
                        autoSkip: false,
                        maxRotation: 45,
                        minRotation: 45,
                        font: {
                            size: 11
                        }
                    }
                },
                y: {
                    beginAtZero: true,
                    title: {
                        display: true,
                        text: '平均等待天数'
                    }
                }
            },
            layout: {
                padding: {
                    bottom: 30
                }
            }
        }
    });
}

async function calculateProgress() {
    try {
        const orderDate = new Date(document.getElementById('orderDate').value);
        const province = document.getElementById('province').value;
        const modelType = document.getElementById('modelType').value;
        
        if (!orderDate || !province || !modelType) {
            alert('请选择订单日期、省份和车型');
            return;
        }
        
        // 计算已经过去的天数
        const today = new Date();
        const daysPassed = Math.floor((today - orderDate) / (1000 * 60 * 60 * 24));

        const response = await fetch('/api/calculate-progress', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json'
            },
            body: JSON.stringify({
                orderDate: orderDate.toISOString(),
                province,
                modelType
            })
        });
        
        const data = await response.json();
        
        if (!response.ok) {
            throw new Error(data.message || data.error || '服务器错误');
        }
        if (data && typeof data.progress === 'number') {
            const progress = data.progress.toFixed(2);
            document.getElementById('progressBar').style.width = `${progress}%`;
            document.getElementById('progressText').textContent = `进度: ${progress}%`;
            
            // 基于进度计算预计总等待天数
            const predictedTotalDays = Math.ceil(daysPassed / (progress / 100));
            estimatedDate = new Date(orderDate);
            estimatedDate.setDate(estimatedDate.getDate() + predictedTotalDays);
            document.getElementById('estimatedDeliveryDate').textContent = 
                `预计交付日期(Beta2.0): ${estimatedDate.toISOString().split('T')[0]}`;

            document.getElementById('confidenceText').textContent = 
                `预测置信度: ${data.confidence.toFixed(1)}% (基于${data.predictionDetails.dataPoints}条数据，` +
                `数据量权重:${data.predictionDetails.confidenceDetails.dataWeight}%, ` +
                `误差权重:${data.predictionDetails.confidenceDetails.errorWeight}%, ` +
                `趋势权重:${data.predictionDetails.confidenceDetails.trendWeight}%)`;
            document.getElementById('trendText').textContent = 
                `交付时间趋势: ${data.trend === '缩短' ? '正在缩短' : '正在延长'}`;
            document.getElementById('recentDeliveryText').textContent = 
                `${data.recentData.period}交付区间: ${data.recentData.min}-${data.recentData.max}天 ` +
                `(${data.recentData.count}单，基于${data.recentData.sampleSize}条历史数据)`;
        } else {
            throw new Error('无效的响应数据');
        }
    } catch (error) {
        console.error('计算进度时出错:', error);
        document.getElementById('progressBar').style.width = '0%';
        document.getElementById('progressText').textContent = '进度: 0%';
        document.getElementById('estimatedDeliveryDate').textContent = '预计交付日期: -';
        alert('计算进度时出错: ' + error.message);
    }
}

async function refreshData() {
    try {
        const province = document.getElementById('provinceFilter').value;
        const model = document.getElementById('modelFilter').value;
        
        const loadingIndicator = document.getElementById('loadingIndicator');
        if (loadingIndicator) loadingIndicator.style.display = 'inline-block';
        
        const response = await fetch('/api/delivery-data', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json'
            },
            body: JSON.stringify({ province, model })
        });
        
        if (!response.ok) {
            throw new Error(`HTTP error! status: ${response.status}`);
        }
        
        const data = await response.json();
        
        if (!data.records || !Array.isArray(data.records)) {
            throw new Error('Invalid data format');
        }
        
        // 更新表格
        updateTable(data);
        // 更新图表
        updateDeliveryTrendChart(data);
        updateProvinceStatsChart(data);
        // 更新统计数据
        updateStats(data);
        
    } catch (error) {
        console.error('获取数据失败:', error);
        alert('获取数据失败: ' + error.message);
    } finally {
        const loadingIndicator = document.getElementById('loadingIndicator');
        if (loadingIndicator) loadingIndicator.style.display = 'none';
    }
}

function updateTable(data) {
    const tbody = document.getElementById('dataTableBody');
    tbody.innerHTML = '';
    
    data.records.forEach(record => {
        const tr = document.createElement('tr');
        const formatDate = (dateStr) => dateStr.split('T')[0];
        tr.innerHTML = `
            <td>${formatDate(record.order_date)}</td>
            <td>${formatDate(record.delivery_date)}</td>
            <td>${record.province}</td>
            <td>${record.model_type}</td>
            <td>${record.exterior_color}</td>
            <td>${record.interior_color}</td>
            <td>${record.waiting_days}</td>
        `;
        tbody.appendChild(tr);
    });
}

function updateStats(data) {
    if (data.statistics) {
        document.getElementById('avgWaitDays').textContent = data.statistics.avg.toFixed(1);
        document.getElementById('minWaitDays').textContent = data.statistics.min;
        document.getElementById('maxWaitDays').textContent = data.statistics.max;
    }
}

async function submitComment() {
    const nickname = document.getElementById('nickname').value.trim();
    const content = document.getElementById('commentContent').value.trim();
    
    if (!nickname || !content) {
        alert('请填写昵称和留言内容');
        return;
    }
    
    try {
        const response = await fetch('/api/comments', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json'
            },
            body: JSON.stringify({ nickname, content })
        });
        
        if (response.ok) {
            alert('留言提交成功，等待审核');
            document.getElementById('nickname').value = '';
            document.getElementById('commentContent').value = '';
            loadComments();
        } else {
            throw new Error('提交失败');
        }
    } catch (error) {
        console.error('提交留言失败:', error);
        alert('提交留言失败，请稍后重试');
    }
}

function escapeHTML(str) {
    return str
        .replace(/&/g, '&amp;')
        .replace(/</g, '&lt;')
        .replace(/>/g, '&gt;')
        .replace(/"/g, '&quot;')
        .replace(/'/g, '&#39;');
}

async function loadComments() {
    try {
        const response = await fetch('/api/comments');
        if (!response.ok) {
            throw new Error(`HTTP error! status: ${response.status}`);
        }
        const comments = await response.json();
        
        if (!Array.isArray(comments)) {
            throw new Error('Invalid comments data format');
        }

        const commentsList = document.getElementById('commentsList');
        if (commentsList) {
            commentsList.innerHTML = comments.map(comment => `
                <div class="comment-item" style="border-bottom: 1px solid #eee; padding: 1.5rem 0;">
                    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 0.8rem;">
                        <span style="color: var(--primary-color); font-weight: 600;">
                            ${escapeHTML(comment.nickname)}
                            ${comment.nickname === 'F0Xy' ? 
                                '<span style="background: var(--primary-color); color: white; padding: 2px 6px; border-radius: 4px; font-size: 12px; margin-left: 8px;">管理员</span>' 
                                : ''}
                        </span>
                        <span style="color: var(--text-secondary); font-size: 0.875rem;">
                            ${new Date(comment.created_at).toLocaleString()}
                        </span>
                    </div>
                    <div style="color: var(--text-primary); line-height: 1.6;">
                        ${escapeHTML(comment.content)}
                    </div>
                </div>
            `).join('') || '<div style="text-align: center; color: var(--text-secondary); padding: 2rem;">暂无评论</div>';
        }
    } catch (error) {
        console.error('加载留言失败:', error);
        const commentsList = document.getElementById('commentsList');
        if (commentsList) {
            commentsList.innerHTML = '<div style="color: var(--primary-color); text-align: center; padding: 2rem;">加载评论失败，请稍后重试</div>';
        }
    }
}

async function initializeFilters() {
    try {
        const response = await fetch('/api/provinces');
        if (!response.ok) {
            throw new Error(`HTTP error! status: ${response.status}`);
        }
        const provinces = await response.json();

        if (!Array.isArray(provinces)) {
            throw new Error('Invalid provinces data format');
        }
        
        const provinceSelects = [
            document.getElementById('province'),
            document.getElementById('provinceFilter')
        ];
        
        provinceSelects.forEach(select => {
            if (select) {
                select.innerHTML = '<option value="">选择省份</option>';
                provinces.forEach(province => {
                    const option = document.createElement('option');
                    option.value = province;
                    option.textContent = province;
                    select.appendChild(option);
                });
            }
        });
        
        await refreshData();
    } catch (error) {
        console.error('初始化过滤器失败:', error);
    }
}

// 初始化
document.addEventListener('DOMContentLoaded', () => {
    initializeFilters().catch(console.error);
    loadComments().catch(console.error);
});

    </script>
</body>
</html>
                <p id="trendText" style="margin-bottom: 0.5rem;"></p>
                <p id="recentDeliveryText"></p>
            </div>
        </div>
    </div>

    <div class="statistics animate-fade-in">
        <div>
            <div style="color: var(--text-secondary); font-size: 0.9rem;">平均等待天数</div>
            <div style="font-size: 2rem; font-weight: 700; color: var(--primary-color); margin: 0.5rem 0;" id="avgWaitDays">-</div>
        </div>
        <div>
            <div style="color: var(--text-secondary); font-size: 0.9rem;">最短等待天数</div>
            <div style="font-size: 2rem; font-weight: 700; color: var(--primary-color); margin: 0.5rem 0;" id="minWaitDays">-</div>
        </div>
        <div>
            <div style="color: var(--text-secondary); font-size: 0.9rem;">最长等待天数</div>
            <div style="font-size: 2rem; font-weight: 700; color: var(--primary-color); margin: 0.5rem 0;" id="maxWaitDays">-</div>
        </div>
    </div>

    <div class="charts-grid animate-fade-in">
